rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Since our app uses the Admin SDK (server-side), 
    // these rules primarily affect potential future client-side additions.
    match /users/{userId} {
      allow read, write: if false; // Only server (Admin SDK) can access
    }

    match /tokens/{tokenId} {
      allow read, write: if false; // Only server (Admin SDK) can access
    }
  }
}
